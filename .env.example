# --- Database ---
# When running via docker-compose, host is the service name "db".
DATABASE_URL=postgresql+psycopg2://voree:voree@db:5432/voree

# --- Anthropic Claude API (Step 5) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Voyage AI embeddings (Step 3) ---
# Anthropic has no native embeddings endpoint; Voyage is the recommended provider.
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIM=1024
