# --- Database ---
# Local (docker-compose): postgresql+psycopg2://voree:voree@db:5432/voree
# Railway: auto-set by the PostgreSQL plugin (DATABASE_URL)
DATABASE_URL=postgresql+psycopg2://voree:voree@db:5432/voree

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Voyage AI embeddings ---
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIM=1024
